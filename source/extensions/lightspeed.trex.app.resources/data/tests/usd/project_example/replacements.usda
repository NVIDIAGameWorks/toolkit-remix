#usda 1.0
(
    customLayerData = {
        string lightspeed_game_name = "testGame"
        string lightspeed_layer_type = "replacement"
        dictionary omni_layer = {
            dictionary muteness = {
            }
        }
    }
    subLayers = [
        @./transfer_workflow_target.usda@,
        @./transfer_workflow_particle_overrides.usda@,
        @./transfer_workflow_second_particle_overrides.usda@
    ]
    upAxis = "Z"
)

over "RootNode"
{
    over "Camera"
    {
        custom uniform vector3d omni:kit:centerOfInterest = (0, 0, -1148.7331652567711)
        float3 xformOp:rotateXYZ = (51.877254, 0.000037718302, -6.3825345)
        float3 xformOp:scale = (0.99997497, 0.99996805, 1.0000205)
        double3 xformOp:translate = (-109.073, 411.363, 962.962)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ", "xformOp:scale"]
    }

    over "meshes"
    {
        def Xform "mesh_FEE1DEADF00D0001"
        {
            def Mesh "mesh"
            {
                float3[] extent = [(0, 0, 0), (1, 1, 0)]
                int[] faceVertexCounts = [3]
                int[] faceVertexIndices = [0, 1, 2]
                point3f[] points = [(0, 0, 0), (1, 0, 0), (0, 1, 0)]
                uniform token subdivisionScheme = "none"

                def OmniGraph "TransferWorkflowLogicGraph"
                {
                    token evaluator:type = "push"
                    int2 fileFormatVersion = (1, 5)

                    def OmniGraphNode "MeshProximity" (
                        prepend apiSchemas = ["NodeGraphNodeAPI"]
                    )
                    {
                        rel inputs:target = </RootNode/meshes/mesh_FEE1DEADF00D0001/mesh>
                        token node:type = "lightspeed.trex.logic.MeshProximity"
                        int node:typeVersion = 1
                    }
                }
            }

            def Xform "reference_override" (
                prepend references = @./sources/transfer_workflow_cube.usda@
            )
            {
                custom bool IsRemixRef = 1

                over "Cube_01"
                {
                    double3 xformOp:rotateXYZ = (0, 0, 0)
                    double3 xformOp:scale = (1, 1, 1)
                    double3 xformOp:translate = (40.97617494664862, -14.462177889626224, -0.000003471705639412903)
                    uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ", "xformOp:scale"]
                }
            }

            def SphereLight "TransferWorkflowLight"
            {
                float inputs:intensity = 1200
            }
        }

        def Xform "transfer_workflow_material_mesh"
        {
            def Mesh "mesh" (
                prepend apiSchemas = ["MaterialBindingAPI"]
            )
            {
                float3[] extent = [(0, 0, 0), (1, 1, 0)]
                int[] faceVertexCounts = [3]
                int[] faceVertexIndices = [0, 1, 2]
                rel material:binding = </RootNode/Looks/transfer_workflow_material> (
                    bindMaterialAs = "weakerThanDescendants"
                )
                point3f[] points = [(0, 0, 0), (1, 0, 0), (0, 1, 0)]
                uniform token subdivisionScheme = "none"
            }
        }

        def Xform "transfer_workflow_particle_definition"
        {
            def Mesh "mesh" (
                prepend apiSchemas = ["ParticleSystemAPI"]
            )
            {
                float3[] extent = [(0, 0, 0), (1, 1, 0)]
                int[] faceVertexCounts = [3]
                int[] faceVertexIndices = [0, 1, 2]
                float primvars:particle:gravityForce = 9.8
                point3f[] points = [(0, 0, 0), (1, 0, 0), (0, 1, 0)]
                uniform token subdivisionScheme = "none"
            }
        }

        def Xform "transfer_workflow_particle_override"
        {
            def Mesh "mesh" (
                prepend apiSchemas = ["ParticleSystemAPI"]
            )
            {
                float3[] extent = [(0, 0, 0), (1, 1, 0)]
                int[] faceVertexCounts = [3]
                int[] faceVertexIndices = [0, 1, 2]
                float primvars:particle:gravityForce = 1
                point3f[] points = [(0, 0, 0), (1, 0, 0), (0, 1, 0)]
                uniform token subdivisionScheme = "none"
            }
        }

        over "mesh_BAC90CAA733B0859" (
            references = None
        )
        {
            def Xform "ref_c89e0497f4ff4dc4a7b70b79c85692da" (
                prepend references = @./sources/cube.usda@
            )
            {
                custom bool IsRemixRef = 1
                double3 xformOp:rotateXYZ = (0, 0, 0)
                double3 xformOp:scale = (1, 1, 1)
                double3 xformOp:translate = (0, 0, 0)
                uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ", "xformOp:scale"]

                over "Cube"
                {
                    float3 xformOp:rotateXYZ = (0, 0, 0)
                    float3 xformOp:scale = (1, 1, 1)
                    double3 xformOp:translate = (40.97617494664862, -14.462177889626224, -0.000003471705639412903)
                    uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ", "xformOp:scale"]
                }
            }
        }

        over "mesh_CED45075A077A49A"
        {
            def Xform "ref_e58b2a90258740278bd55cd166bf7ba3" (
                prepend references = @./ingested_assets/output/good/nested_lighting.usda@
            )
            {
                custom bool IsRemixRef = 1

                over "Klab_A"
                {
                    over "PrimaryLights"
                    {
                        over "TankA"
                        {
                            float inputs:intensity = 80
                        }

                        over "TankB"
                        {
                            float inputs:intensity = 40
                        }
                    }
                }
            }
        }
    }

    over "instances"
    {
        def Xform "inst_FEE1DEADF00D0001_0" (
            prepend references = </RootNode/meshes/mesh_FEE1DEADF00D0001>
        )
        {
        }
    }

    over "Looks"
    {
        token visibility = "invisible"

        over "mat_BC868CE5A075ABB1"
        {
            over "Shader"
            {
                asset inputs:metallic_texture = @./sources/textures/T_MetalPanelWall_HeavyRust_metallic.png@ (
                    colorSpace = "raw"
                    customData = {
                        asset default = @@
                    }
                    displayGroup = "Specular"
                    displayName = "Metallic Map"
                    hidden = false
                    renderType = "texture_2d"
                )
                asset inputs:normalmap_texture = @./sources/textures/T_MetalPanelWall_HeavyRust_normal.png@ (
                    colorSpace = "sRGB"
                    customData = {
                        asset default = @@
                    }
                    displayGroup = "Normal"
                    displayName = "Normal Map"
                    hidden = false
                )
                asset inputs:reflectionroughness_texture = @./sources/textures/T_MetalPanelWall_HeavyRust_roughness.png@ (
                    colorSpace = "raw"
                    customData = {
                        asset default = @@
                    }
                    displayGroup = "Specular"
                    displayName = "Roughness Map"
                    hidden = false
                )
            }
        }

        def Material "transfer_workflow_material"
        {
            token outputs:surface.connect = </RootNode/Looks/transfer_workflow_material/Shader.outputs:surface>

            def Shader "Shader"
            {
                token outputs:surface
                float inputs:transferWorkflowRoughness = 0.42 (
                    displayGroup = "Specular"
                    displayName = "Transfer Workflow Roughness"
                    hidden = false
                )
            }
        }
    }
}
