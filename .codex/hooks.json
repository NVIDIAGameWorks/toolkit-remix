{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./.agents/scripts/run_packman_python.cmd .agents/hooks/run_stop_checks.py --agent=codex .agents/hooks/check_completion_gates.py .agents/hooks/check_memory_promotion.py",
            "commandWindows": "cmd.exe /c .agents\\scripts\\run_packman_python.cmd .agents/hooks/run_stop_checks.py --agent=codex .agents/hooks/check_completion_gates.py .agents/hooks/check_memory_promotion.py",
            "statusMessage": "Checking completion gates"
          }
        ]
      }
    ]
  }
}
